@model Product

<div class="col-6 col-md-4 col-lg-3 mb-4">
    <div class="card product-card p-3 shadow-sm h-100 border-0 rounded-3">
        <div class="text-center mb-3">
        </div>

        <div class="card-body p-0 d-flex flex-column h-100">
            <h6 class="card-title fw-bold mb-2 text-dark" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                @Model?.Name
            </h6>

            <p class="card-text text-secondary small text-truncate mb-3">
                @Model?.Description
            </p>

            <div>
                <div class="mb-3">
                    <span class="text-danger fw-bold" style="font-size: 1.05rem;">
                        @Model?.Price.ToString("c")
                    </span>
                </div>

                <form id="@Model?.ProductID" asp-page="/Cart" method="post" class="mt-3 d-flex justify-content-center">
                    <input type="hidden" asp-for="ProductID" />
                    <input type="hidden" name="returnUrl" value="@ViewContext.HttpContext.Request.PathAndQuery()" />

                    <button type="submit"
                            class="btn bg-custom-gradient text-white fw-bold shadow-sm rounded-pill d-flex align-items-center justify-content-center text-nowrap px-3 border-0"
                            style="height: 38px; min-width: 125px; font-size: 0.85rem;">
                        Thêm vào giỏ
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>