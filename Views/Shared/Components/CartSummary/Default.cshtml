@model Cart

<div class="">
    <a class="btn btn-cart-summary d-flex justify-content-center align-items-center position-relative shadow"
       asp-page="/Cart"
       style="background-color: #ffffff; width: 45px; height: 45px; border-radius: 10px; border: none; transition: transform 0.2s;">

        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="#D70018" class="bi bi-cart3" viewBox="0 0 16 16">
            <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .49.598l-1 5a.5.5 0 0 1-.465.401l-9.397.472L4.415 11H13a.5.5 0 0 1 0 1H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5zM3.102 4l.84 4.479 9.144-.459L13.89 4H3.102zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z" />
        </svg>

        @if (Model?.Lines.Count() > 0)
        {
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-white border border-light shadow-sm"
                  style="color: #D70018; font-size: 0.8rem; padding: 0.35em 0.6em;">
                @Model.Lines.Sum(x => x.Quantity)
                <span class="visually-hidden">sản phẩm trong giỏ</span>
            </span>
        }
    </a>
</div>