<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Trang chủ - SportsStore</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="bg-custom-gradient text-white p-3 shadow-sm mb-4">
        <div class="container d-flex justify-content-between align-items-center">
            <a href="/" class="navbar-brand fw-bold fs-4 m-0 text-white text-decoration-none">
                Hệ thống SportsStore
            </a>

            <div>
            </div>
        </div>
    </div>

    <div class="container">
        <div class="row">
            <div id="categories" class="col-md-3 mb-4">
                <vc:navigation-menu />
            </div>

            <div class="col-md-9">
                @RenderBody()
            </div>
        </div>
    </div>
</body>
</html>