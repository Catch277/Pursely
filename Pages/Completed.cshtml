@page

<div class=".product-section-bg text-center card card-elevated rounded-4 p-5 mx-auto mt-5 border-0" style="max-width: 600px;">
    <h2 class="fw-bold mb-3" style="color: #D70018;">Cảm ơn quý khách</h2>

    <p class="fs-5 text-dark mb-2">
        Cảm ơn bạn đã đặt hàng với mã đơn <span class="fw-bold" style="color: #D70018;">#@OrderId</span>
    </p>

    <p class="text-secondary mb-4">Đơn hàng của bạn sẽ được giao sớm nhất có thể.</p>

    <a class="btn bg-custom-gradient text-white fw-bold shadow-sm rounded-pill px-4 py-2 border-0 d-inline-block mx-auto"
       style="min-width: 200px;"
       asp-controller="Home">
        Quay về cửa hàng
    </a>
</div>

@functions {
    [BindProperty(SupportsGet = true)]
    public string? OrderId { get; set; }
}